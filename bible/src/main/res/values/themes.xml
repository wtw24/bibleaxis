<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="SplashTheme" parent="@style/Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@color/splash_background</item>
    </style>

    <style name="Theme.BibleAxis" parent="@style/Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/primary</item>
        <item name="android:windowOptOutEdgeToEdgeEnforcement">true</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:textColorPrimary">@color/black</item>
        <item name="actionButtonStyle">@style/ActionMenuButtonStyle</item>
        <item name="android:actionButtonStyle">@style/ActionMenuButtonStyle</item>
        <!-- Action bar -->
        <item name="actionBarStyle">@style/ActionBar</item>
        <item name="actionMenuTextColor">@color/toolbarTextColor</item>
        <!-- Action mode -->
        <item name="windowActionModeOverlay">false</item>
        <item name="actionModeStyle">@style/ActionModeStyle</item>
        <item name="actionModeBackground">@color/action_mode_background</item>
        <item name="actionModeCloseDrawable">@drawable/ic_close</item>
        <item name="preferenceTheme">@style/PreferenceThemeOverlay</item>
    </style>

    <style name="Theme.BibleAxis.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <!-- Action mode -->
        <item name="windowActionModeOverlay">true</item>
    </style>

    <style name="ToolbarStyle">
        <item name="android:theme">@style/ToolbarTheme</item>
        <item name="popupTheme">@style/ToolbarPopupTheme</item>
        <item name="android:background">@color/primary</item>
        <item name="titleTextAppearance">@style/TitleText</item>
        <item name="subtitleTextAppearance">@style/SubtitleText</item>
    </style>

    <style name="ToolbarTheme">
        <item name="android:textColorPrimary">@color/toolbarTextColor</item>
        <item name="android:textColorSecondary">@color/toolbarTextColor</item>
        <item name="colorControlNormal">@color/toolbarTextColor</item>
        <item name="actionButtonStyle">@style/ActionMenuButtonStyle</item>
        <item name="android:actionButtonStyle">@style/ActionMenuButtonStyle</item>
        <!--<item name="actionMenuTextColor">@color/toolbarTextColor</item>-->
    </style>

    <style name="ActionMenuButtonStyle" parent="Widget.AppCompat.ActionButton">
        <item name="android:drawablePadding">@dimen/action_icon_text_spacing</item>
    </style>

    <style name="ToolbarPopupTheme" parent="Base.ThemeOverlay.AppCompat.ActionBar">
        <item name="android:background">@color/toolbarTextColor</item>
        <item name="android:textColorPrimary">@color/primary</item>
    </style>

    <!-- Action mode -->

    <style name="ActionModeStyle" parent="Base.Widget.AppCompat.ActionMode">
        <item name="titleTextStyle">@style/TitleText</item>
        <item name="subtitleTextStyle">@style/SubtitleText</item>
    </style>

    <!-- Action bar -->

    <style name="ActionBar" parent="Base.Widget.AppCompat.Light.ActionBar.Solid">>
        <item name="titleTextStyle">@style/TitleText</item>
        <item name="subtitleTextStyle">@style/SubtitleText</item>
    </style>

    <style name="TitleText" parent="Base.TextAppearance.AppCompat.Widget.ActionBar.Title">>
        <item name="android:textColor">@color/toolbarTextColor</item>
    </style>

    <style name="SubtitleText" parent="Base.TextAppearance.AppCompat.Widget.ActionBar.Subtitle">
        <item name="android:textColor">@color/toolbarTextColor</item>
        <item name="android:textSize">@dimen/text_size_very_small</item>
    </style>

</resources>
