<?xml version="1.0" encoding="utf-8"?>
<resources>
	<declare-styleable name="NumberChoiseView">
		<attr name="minValue" format="integer"/>
		<attr name="maxValue" format="integer"/>
		<attr name="totalValue" format="integer"/>
	</declare-styleable>

	<!-- List items related attributes -->
	<declare-styleable name="Item">
		<attr name="enabled" format="boolean" />
	</declare-styleable>
	<declare-styleable name="TextItem">
		<attr name="text" format="string" />
	</declare-styleable>
	<declare-styleable name="SubtitleItem">
		<attr name="subtitletext" format="string" />
	</declare-styleable>
	<declare-styleable name="SubtextItem">
		<attr name="subtext" format="string" />
	</declare-styleable>

</resources>