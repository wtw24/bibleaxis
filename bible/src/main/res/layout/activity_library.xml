<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:paddingLeft="@dimen/default_margin"
        android:paddingTop="@dimen/default_margin_min"
        android:paddingRight="@dimen/default_margin"
        android:paddingBottom="@dimen/default_margin_min">

        <Button
            android:id="@+id/btnBook"
            style="@style/LibraryPickerButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="3dp"
            android:layout_weight="4.2"
            android:drawableEnd="@drawable/ic_library_chevron_down"
            android:drawablePadding="10dp"
            android:drawableRight="@drawable/ic_library_chevron_down"
            android:elevation="0dp"
            android:gravity="center"
            android:stateListAnimator="@null"
            android:textAllCaps="false"
            android:translationZ="0dp"
            tools:text="-----"/>

        <Button
            android:id="@+id/btnChapter"
            style="@style/LibraryPickerButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="3dp"
            android:layout_weight="1.6"
            android:drawableEnd="@drawable/ic_library_chevron_down"
            android:drawablePadding="8dp"
            android:drawableRight="@drawable/ic_library_chevron_down"
            android:elevation="0dp"
            android:gravity="center"
            android:stateListAnimator="@null"
            android:translationZ="0dp"
            tools:text="0"/>

        <Button
            android:id="@+id/btnModule"
            style="@style/LibraryPickerButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="3dp"
            android:layout_weight="4"
            android:drawableEnd="@drawable/ic_library_chevron_down"
            android:drawablePadding="10dp"
            android:drawableRight="@drawable/ic_library_chevron_down"
            android:elevation="0dp"
            android:ellipsize="end"
            android:gravity="center"
            android:lineSpacingExtra="8dp"
            android:maxLines="2"
            android:singleLine="false"
            android:stateListAnimator="@null"
            android:translationZ="0dp"
            tools:text="---"/>

        <ImageButton
            android:id="@+id/btnApply"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_margin="3dp"
            android:background="@drawable/bg_library_apply"
            android:contentDescription="@string/library_apply"
            android:elevation="0dp"
            android:minWidth="40dp"
            android:minHeight="40dp"
            android:paddingLeft="18dp"
            android:paddingTop="10dp"
            android:paddingRight="18dp"
            android:paddingBottom="10dp"
            android:scaleType="center"
            android:stateListAnimator="@null"
            android:src="@drawable/ic_library_apply"
            android:translationZ="0dp"
            tools:ignore="ContentDescription"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:orientation="horizontal">

        <ListView
            android:id="@+id/modules"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            tools:listitem="@layout/item_list"/>

        <ListView
            android:id="@+id/books"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"/>

        <LinearLayout
            android:id="@+id/chapterContainer"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:orientation="vertical"
            android:paddingStart="@dimen/default_margin"
            android:paddingTop="@dimen/ch_chapter_spacing"
            android:paddingEnd="@dimen/default_margin"
            android:visibility="gone">

            <TextView
                android:id="@+id/chapterLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:layout_marginBottom="@dimen/default_margin_min"
                android:gravity="center"
                android:text="@string/library_chapter_label"
                android:textAlignment="center"
                android:textColor="@color/dark_gray"
                android:textSize="@dimen/text_size_small"
                android:textStyle="bold"/>

            <GridView
                android:id="@+id/chapterChoose"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:columnWidth="@dimen/ch_chapter_width"
                android:gravity="start"
                android:horizontalSpacing="@dimen/ch_chapter_spacing"
                android:numColumns="auto_fit"
                android:paddingStart="3dp"
                android:paddingEnd="3dp"
                android:verticalSpacing="@dimen/ch_chapter_spacing"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
